# =============================================================================
# otbrstack — environment variables
#
# Usage:
#   cp .env.example .env
#   # edit .env with your values
#   otbrstack flash /dev/sdX
#
# Or point to any file explicitly:
#   otbrstack flash --env-file=/path/to/this.env /dev/sdX
#
# The env file is sourced automatically; no export or sudo -E needed.
# =============================================================================

# Snap channel for openthread-border-router. The snap is not on stable;
# use latest/edge or latest/beta.
OTBR_SNAP_CHANNEL="latest/edge"

# Wi-Fi credentials written into the cloud-init netplan config.
# wlan0 is used as fallback when eth0 is not present.
WIFI_SSID="YourNetworkName"
WIFI_PASSWORD="YourWiFiPassword"

# Thread Active Operational Dataset TLV (hex string).
# Generate with: ot-ctl dataset init new && ot-ctl dataset active -x
# Or export from an existing Thread commissioner.
THREAD_DATASET_TLV="0e080000000000010000..."

# SSH public key injected into VMs and Raspberry Pi images via cloud-init.
# Grants SSH access to the ubuntu user. Provide as many keys as you like
# (one per line, inside the quotes as a YAML block or just one key).
# For otbrstack vm: SSH is not needed — incus exec is used instead.
SSH_PUBKEY=""

# ESP32-C6 RCP firmware path (optional).
# If set, the script will flash this binary when the RCP has no Spinel response.
# Build from source with ESP-IDF (ot_rcp example), then place the app binary here:
#   cp .../build/esp_ot_rcp.bin cache/esp32/rcp/
#   RCP_FIRMWARE_PATH=cache/esp32/rcp/esp_ot_rcp.bin
# Leave empty to use the URL download path instead (RCP_FIRMWARE_URL below).
RCP_FIRMWARE_PATH=""

# RCP firmware download URL (optional override).
# Defaults in the scripts to the binary committed in this repo on GitHub.
# Override here only if you're hosting the firmware elsewhere or using a
# different build (e.g. a merged image that flashes at 0x0).
#RCP_FIRMWARE_URL=https://raw.githubusercontent.com/farscapian/otbr-commissioner-stacks/main/cache/esp32/rcp/esp_ot_rcp.bin
#RCP_FLASH_ADDR=0x10000

# Simulated ot-rcp binary (used when no physical RCP is attached).
# Pre-built binaries: https://github.com/espressif/esp-thread-br/releases
# Cached automatically at cache/ot-rcp-sim/ot-rcp when SIM_RCP_URL is set.
SIM_RCP_BIN="$SCRIPT_DIR/cache/esp32/esp_ot_rcp.bin"
SIM_RCP_URL=""

# Simulated ot-cli binary (used by tests/test_otbr_vm.sh for T6 neighbor exchange).
# Must match the instance architecture (amd64 or arm64).
# Build from OpenThread source:
#   cd openthread && ./script/cmake-build simulation
#   cp build/simulation/examples/apps/cli/ot-cli cache/ot-rcp-sim/ot-cli
SIM_CLI_BIN=""
SIM_CLI_URL=""

# Device hostname written into cloud-init meta-data.
# Override per-device with --hostname=NAME on the command line (preferred for
# multi-device deploys so one shared .env works for all units).
# Default: otbr-raspi4
#OTBR_HOSTNAME=otbr-raspi4

# Skip RCP Spinel firmware verification during first-boot (development only).
# Set to 1 to bypass the probe when debugging issues unrelated to the RCP.
SKIP_RCP_VERIFY=0

# UFW: space-separated list of CIDRs/IPs allowed to SSH into the device.
# Leave empty to allow SSH from anywhere (not recommended for production).
# Example: SSH_MGMT_CIDRS="192.168.4.25 192.168.4.30 192.168.4.31"
SSH_MGMT_CIDRS=""
